---
layout: null
---
[
  {% for post in site.posts limit:5 %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | prepend: site.baseurl | prepend: site.url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
